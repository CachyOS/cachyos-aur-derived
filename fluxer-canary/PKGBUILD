# Maintainer: witchlliee <witchlliee@tuta.io>

pkgname=fluxer-canary
pkgver=2026.606.140333
pkgrel=1
pkgdesc="A free and open source group chat, video, and voice calling app"
arch=('x86_64')
options=(!strip)
url="https://canary.fluxer.app"
license=('AGPL-3.0-only')
depends=('gtk3' 'nss' 'alsa-lib' 'libxss' 'libnotify' 'nspr')
source=(
  "fluxer-canary-${pkgver}-x64.tar.gz::https://api.fluxer.app/dl/desktop/canary/linux/x64/${pkgver}/tar_gz"
  "fluxer-canary.desktop"
)
sha256sums=('b12fa03366824d534afcc77964179db2163aa8271593607885ba08a8538ed559'
            '5869bf60c8bc53494fa7dc29eaeda36273f2d1054ac1edd1bf0e90589c7e90b8')

package() {
    _srcdir="Fluxer Canary-${pkgver}-linux-x64"

    cd "$_srcdir"

    install -d "$pkgdir"/opt/$pkgname
    cp -r . "$pkgdir"/opt/$pkgname/

    install -d "$pkgdir"/usr/bin
    ln -s /opt/$pkgname/fluxer-canary "$pkgdir"/usr/bin/fluxer-canary

    install -d "$pkgdir"/usr/share/icons/hicolor/{256x256/apps/,512x512/apps/}
    install -Dm644 "$srcdir"/fluxer-canary.desktop "$pkgdir"/usr/share/applications/fluxer-canary.desktop
    ln -srv /opt/$pkgname/resources/icons/256x256.png "$pkgdir"/usr/share/icons/hicolor/256x256/apps/fluxer-canary.png
    ln -srv /opt/$pkgname/resources/icons/512x512.png "$pkgdir"/usr/share/icons/hicolor/512x512/apps/fluxer-canary.png
}
