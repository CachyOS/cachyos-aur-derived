+const char *
+rxvt_term::get_def_color(int idx)
+{
+  const char *color;
+
+  color = def_colors[idx];
+  if (!color) {
+    // If cursor colors are not defined, use fg/bg respectively.
+    switch (idx) {
+    case Color_cursor:
+      color = def_colors[Color_fg];
+      break;
+    case Color_cursor2:
+      color = def_colors[Color_bg];
+      break;
+    }
+  }
+
+  return color;
+}
