# Maintainer: NelloKudo <marshnelloosu@gmail.com>

pkgname=iloader
pkgver=2.2.7
pkgrel=1
pkgdesc="User-friendly sideloader"
arch=('x86_64' 'aarch64')
url="https://github.com/nab138/iloader"
license=('MIT' 'custom')
options=('!lto')
depends=(
  'gtk3'
  'hicolor-icon-theme'
  'libsoup3'
  'usbmuxd'
  'webkit2gtk-4.1'
)
makedepends=(
  'bun'
  'cargo'
)
optdepends=('libayatana-appindicator: system tray icon support')
conflicts=('iloader-appimage' 'iloader-bin')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz"
        "$pkgname.desktop")
sha256sums=('30072c457d82ca6816612ee1a3efd74e27f2ba56d796ff4e027ce1daf20f2d53'
            '755768d09b767b37df904b2afd092c9e52263d5a9752780a1b054f6229d8fa92')

prepare() {
  cd "$pkgname-$pkgver"

  bun install --frozen-lockfile
  cargo fetch --manifest-path src-tauri/Cargo.toml --locked --target host-tuple
}

build() {
  cd "$pkgname-$pkgver"

  bunx tauri build --no-bundle --config src-tauri/ci.conf.json
}

package() {
  cd "$pkgname-$pkgver"

  install -Dm755 "src-tauri/target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"

  for i in 32x32 128x128 128x128@2x; do
    install -Dm644 "src-tauri/icons/${i}.png" \
      "$pkgdir/usr/share/icons/hicolor/${i/@2x/@2}/apps/$pkgname.png"
  done

  install -Dm644 src-tauri/icons/icon.png \
    "$pkgdir/usr/share/icons/hicolor/512x512/apps/$pkgname.png"

  install -Dm644 "$srcdir/$pkgname.desktop" -t "$pkgdir/usr/share/applications/"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 LICENSE-BRANDING "$pkgdir/usr/share/licenses/$pkgname/LICENSE-BRANDING"
}
